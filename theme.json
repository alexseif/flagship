{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "1200px",
      "wideSize": "1600px"
    },
    "color": {
      "palette": [
        {
          "slug": "primary",
          "color": "#0F172A",
          "name": "Primary"
        },
        {
          "slug": "secondary",
          "color": "#3B82F6",
          "name": "Secondary"
        },
        {
          "slug": "foreground",
          "color": "#1E293B",
          "name": "Foreground"
        },
        {
          "slug": "background",
          "color": "#FFFFFF",
          "name": "Background"
        },
        {
          "slug": "surface",
          "color": "#F1F5F9",
          "name": "Surface"
        },
        {
          "slug": "contrast",
          "color": "#000000",
          "name": "Contrast"
        }
      ]
    },
    "typography": {
      "fluid": true,
      "fontFamilies": [
        {
          "fontFamily": "Inter, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif",
          "slug": "system-sans",
          "name": "System Sans"
        },
        {
          "fontFamily": "Georgia, Cambria, 'Times New Roman', Times, serif",
          "slug": "system-serif",
          "name": "System Serif"
        }
      ],
      "fontSizes": [
        {
          "slug": "small",
          "size": "clamp(0.875rem, 0.875rem + ((1vw - 0.2rem) * 0.227), 1rem)",
          "name": "Small"
        },
        {
          "slug": "medium",
          "size": "clamp(1rem, 1rem + ((1vw - 0.2rem) * 0.227), 1.125rem)",
          "name": "Medium"
        },
        {
          "slug": "large",
          "size": "clamp(1.125rem, 1.125rem + ((1vw - 0.2rem) * 0.682), 1.5rem)",
          "name": "Large"
        },
        {
          "slug": "x-large",
          "size": "clamp(1.5rem, 1.5rem + ((1vw - 0.2rem) * 1.364), 2.25rem)",
          "name": "Extra Large"
        },
        {
          "slug": "xx-large",
          "size": "clamp(1.75rem, 3vw, 2.5rem)",
          "name": "Extra Extra Large"
        },
        {
          "slug": "hero",
          "size": "clamp(2.5rem, 5vw, 4rem)",
          "name": "Hero"
        }
      ]
    },
    "spacing": {
      "spacingScale": {
        "steps": 0
      },
      "spacingSizes": [
        {
          "size": "clamp(1rem, 2vw, 1.5rem)",
          "slug": "small",
          "name": "Small"
        },
        {
          "size": "clamp(1.5rem, 3vw, 2rem)",
          "slug": "medium",
          "name": "Medium"
        },
        {
          "size": "clamp(2rem, 4vw, 3rem)",
          "slug": "large",
          "name": "Large"
        },
        {
          "size": "clamp(3rem, 6vw, 4.5rem)",
          "slug": "x-large",
          "name": "Extra Large"
        },
        {
          "size": "clamp(4.5rem, 8vw, 7rem)",
          "slug": "xx-large",
          "name": "Extra Extra Large"
        }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--background)",
      "text": "var(--wp--preset--color--foreground)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--system-sans)",
      "fontSize": "var(--wp--preset--font-size--medium)",
      "lineHeight": "1.6"
    },
    "elements": {
      "h1": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--hero)",
          "lineHeight": "1.2",
          "fontWeight": "700"
        }
      },
      "h2": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--xx-large)",
          "lineHeight": "1.3",
          "fontWeight": "700"
        }
      },
      "h3": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--x-large)",
          "lineHeight": "1.4",
          "fontWeight": "600"
        }
      },
      "h4": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--large)",
          "lineHeight": "1.5",
          "fontWeight": "600"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--secondary)"
        }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--background)"
        },
        "border": {
          "radius": "4px"
        }
      }
    },
    "blocks": {
      "core/cover": {
        "spacing": {
          "margin": {
            "top": "0"
          },
          "padding": {
            "top": "0"
          }
        }
      },
      "core/group": {
        "spacing": {
          "margin": {
            "top": "0"
          },
          "padding": {
            "top": "0"
          }
        }
      }
    }
  }
}
